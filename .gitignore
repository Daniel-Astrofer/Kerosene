# Documentation and generated analysis outputs kept local.
**/*.md
!/.gitignore
!/.gitattributes
frontend/*.txt
frontend/**/*.txt
!frontend/**/CMakeLists.txt
frontend/Get
frontend/Process
frontend/Run
frontend/=*
