# Kerosene repository policy
# Track project source only under backend/ and frontend/.

*
!/.gitignore
!/.gitattributes
!/backend/
!/backend/**
!/frontend/
!/frontend/**
!/infra/
!/infra/**
!/docs/
!/docs/**
!/docs-final/
!/docs-final/**
!/scripts/
!/scripts/**
!/.github/
!/.github/**
!/docker-compose.yml
!/README.md

# Root-level material kept local only.
/.local/
/.local/**
/assets/
/assets/**
/backups/
/backups/**
/screenshots/
/screenshots/**
/vault/
/vault/**
/mpc-sidecar/
/mpc-sidecar/**
/kerosene-infrastructure/
/kerosene-infrastructure/**
/gradle/
/gradle/**
/gradlew
/gradlew.bat
/README*
/DAYLY_LOG.md
/*.html
/projeto_completo_kerosene.txt
/start-local.sh
/arm-vault.*
/cert-generator.sh
/panic.sh

# Secrets and local credentials.
**/.env
**/.env.*
!**/.env.example
**/*.secret
**/*.key
**/*.pem
**/*.pub
**/*.jks
**/*.p12
**/*.pfx
**/*.keystore
**/google-services.json
**/service-account.json
**/key.properties
**/certs/
**/certs/**
**/identity/
**/identity/**
**/tor-keys/
**/tor-keys/**
**/tor/keys/
**/tor/keys/**
**/hostname
**/hs_ed25519_*
**/onion_auth_*/
**/onion_auth_*/**

# Build output, caches and IDE state.
**/.gradle/
**/.gradle/**
**/.kotlin/
**/.kotlin/**
**/.dart_tool/
**/.dart_tool/**
**/.pub-cache/
**/.pub-cache/**
**/.pub/
**/.pub/**
**/build/
**/build/**
**/*.root-owned-*
**/*.root-owned-*/**
**/target/
**/target/**
**/out/
**/out/**
!**/src/main/java/**/application/port/out/
!**/src/main/java/**/application/port/out/**
!**/src/test/java/**/application/port/out/
!**/src/test/java/**/application/port/out/**
**/bin/
**/bin/**
**/coverage/
**/coverage/**
**/.idea/
**/.idea/**
**/.vscode/
**/.vscode/**
**/.metadata
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/*.iml
**/*.iws
**/*.ipr
**/*.class
**/*.log
**/*.pyc
**/*.swp
**/.DS_Store
**/Thumbs.db

# Documentation and generated analysis outputs kept local.
**/*.md
!/README.md
!/STORYBOOK_SCREEN_INVENTORY.md
!/docs/**/*.md
!/docs-final/**/*.md
!/infra/**/*.md
!/backend/**/docs/**/*.md
!/backend/adapters/**/*.md
!/backend/kerosene/*.md
!/frontend/lib/FRONTEND_CLEANUP_RULES.md
!/.gitignore
!/.gitattributes
frontend/*.txt
frontend/**/*.txt
!frontend/**/CMakeLists.txt
!frontend/FRONTEND_GUIDELINES.md
frontend/*.png
frontend/Get
frontend/Process
frontend/Run
frontend/=*
frontend/scripts/
frontend/scripts/**

