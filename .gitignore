# Kerosene repository policy
# Track project source only under backend/ and frontend/.

*
!/.gitignore
!/.gitattributes
!/backend/
!/backend/**
!/frontend/
!/frontend/**

# Root-level material kept local only.
/docs/
/docs/**
/scripts/
/scripts/**
/assets/
/assets/**
/screenshots/
/screenshots/**
/vault/
/vault/**
/mpc-sidecar/
/mpc-sidecar/**
/kerosene-infrastructure/
/kerosene-infrastructure/**
/gradle/
/gradle/**
/gradlew
/gradlew.bat
/README*
/DAYLY_LOG.md
/*.html
/projeto_completo_kerosene.txt
/start-local.sh
/arm-vault.*
/cert-generator.sh
/panic.sh

# Agent and assistant tooling.
/.agent/
/.agent/**
/.agents/
/.agents/**
/.codex
/.codex/
/.codex/**
/.claude/
/.claude/**
/.opencode
/.openclaude-profile.json
**/.agent/
**/.agent/**
**/.agents/
**/.agents/**
**/.codex
**/.codex/
**/.codex/**
