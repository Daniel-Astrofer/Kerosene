#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"
export KEROSENE_MCP_ROOT="${KEROSENE_MCP_ROOT:-/home/omega/Kerosene}"
export KEROSENE_MCP_DEFAULT_SEARCH_TIMEOUT_SECONDS="${KEROSENE_MCP_DEFAULT_SEARCH_TIMEOUT_SECONDS:-900}"
export KEROSENE_MCP_MAX_SEARCH_TIMEOUT_SECONDS="${KEROSENE_MCP_MAX_SEARCH_TIMEOUT_SECONDS:-5400}"
export KEROSENE_MCP_DEFAULT_SEARCH_RESPONSE_CHARS="${KEROSENE_MCP_DEFAULT_SEARCH_RESPONSE_CHARS:-750000}"
export KEROSENE_MCP_MAX_SEARCH_RESPONSE_CHARS="${KEROSENE_MCP_MAX_SEARCH_RESPONSE_CHARS:-2000000}"
export KEROSENE_MCP_MAX_TOOL_RESPONSE_CHARS="${KEROSENE_MCP_MAX_TOOL_RESPONSE_CHARS:-1500000}"

exec python3 "$SCRIPT_DIR/kerosene_readonly_mcp.py" "$@"
