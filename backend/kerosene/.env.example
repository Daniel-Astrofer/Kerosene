# ══════════════════════════════════════════════════════════════════
# Kerosene — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=api_system
POSTGRES_PASSWORD=CHANGE_ME_strong_passphrase_here

# ─── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_passphrase

# Local host ports
WEB_ADMIN_PORT=3000
PROMETHEUS_PORT=19090

# ─── Spring Boot Secrets ──────────────────────────────────────────
# Internal service/API key used by local operational flows.
# Generate: openssl rand -hex 32
API_KEY=CHANGE_ME_api_key

# AES-256 key (32 random bytes, base64-encoded)
# Generate: openssl rand -base64 32
AES_SECRET=CHANGE_ME_aes256_base64_key

# JWT signing secret (HS512 — use 64+ random bytes)
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_jwt_secret

# Password hashing pepper. Use a long random value and keep it stable.
# Generate: openssl rand -base64 64
PASSWORD_PEPPER=CHANGE_ME_password_pepper

# HMAC secret used by treasury integrity listeners.
# Generate: openssl rand -base64 64
HMAC_SECRET_KEY=CHANGE_ME_hmac_secret

# Per-shard local shared secrets.
# Generate each one independently: openssl rand -hex 32
SHARD_SECRET_KEY_IS=CHANGE_ME_is_shard_secret
SHARD_SECRET_KEY_CH=CHANGE_ME_ch_shard_secret
SHARD_SECRET_KEY_SG=CHANGE_ME_sg_shard_secret

# Founder/admin TOTP secret used by audit/admin flows.
FOUNDER_TOTP_SECRET=CHANGE_ME_founder_totp_secret

# Vault arming quorum. Each director secret is base64 for 32+ random bytes.
# Generate director secrets: openssl rand -base64 32
# Format: director-id:base64secret,director-id:base64secret
VAULT_REQUIRED_APPROVALS=2
VAULT_ARM_DIRECTORS=director-1,director-2
VAULT_DIRECTOR_HMAC_SECRETS=director-1:CHANGE_ME_director1_hmac_base64,director-2:CHANGE_ME_director2_hmac_base64,director-3:CHANGE_ME_director3_hmac_base64
# Optional fallback for the compose arming container if openssl is unavailable inside the image.
DIRECTOR_1_ARM_SIGNATURE=
DIRECTOR_2_ARM_SIGNATURE=
DIRECTOR_3_ARM_SIGNATURE=

# MPC sidecar enclave storage key (separate from AES_SECRET).
# Generate: openssl rand -base64 32
MPC_MASTER_KEY_B64=CHANGE_ME_mpc_master_key_base64

# Shared container attestation secret for Vault provisioning over Tor.
# Generate: openssl rand -base64 32
VAULT_CLUSTER_ATTESTATION_SECRET=CHANGE_ME_cluster_attestation_secret_base64
VAULT_RAFT_ENABLED=true
VAULT_RAFT_REQUIRED=true
VAULT_RAFT_EXPECTED_SERVERS=3
VAULT_RAFT_URL=https://vault-raft-1:8200
VAULT_RAFT_TOKEN_FILE=/vault-raft/app-health-token

# Release snapshot / internal attestation. Generate with:
#   bash scripts/release-snapshot.sh generate
RELEASE_ATTESTATION_REQUIRED=true
RELEASE_REMOTE_ATTESTATION_ENABLED=true
RELEASE_ATTESTATION_SECRET=CHANGE_ME_release_attestation_secret
RELEASE_MANIFEST_PATH=/release/release-manifest.json
RELEASE_MANIFEST_SIGNATURE_PATH=/release/release-manifest.json.sig
RELEASE_MANIFEST_PUBLIC_KEY_PATH=/release/release-public-key.der.b64
GIT_COMMIT=unknown
BUILD_TIME=unknown
IMAGE_DIGEST=unknown
CODE_HASH=unknown
CONFIG_HASH=unknown

# Mobile release metadata served by /api/public/mobile-download.
MOBILE_RELEASE_VERSION=1.0.0
MOBILE_RELEASE_BUILD_NUMBER=1
MOBILE_ANDROID_URL=
MOBILE_IOS_URL=
MOBILE_ANDROID_SHA256=80158a61b982eb4db95cd010d63ca3d5b52d3e2215c8d9df046a6609db960582
MOBILE_IOS_SHA256=
MOBILE_SIGNING_CERT_SHA256=
MOBILE_CHANGELOG=Initial Android release with secure wallet, passkeys, payment links, and web admin integration.

# Schema migrations. New production databases run Flyway; existing docker-init
# volumes are baselined automatically and then receive idempotent hardening SQL.
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true

# Public frontend origins. Production must not use localhost or wildcard.
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Passkey relying-party metadata for the app-scoped Ed25519 device key.
# This is intentionally not the browser host, so passkeys survive onion changes.
WEBAUTHN_RP_ID=kerosene-device
WEBAUTHN_RP_NAME=Kerosene
WEBAUTHN_ORIGINS=android:apk-key-hash:kerosene,http://localhost:3000,http://localhost:8080

# ─── Bitcoin Core pruned mainnet / LND ────────────────────────────
BITCOIN_NETWORK=mainnet
BITCOIN_CHAIN=mainnet
BITCOIN_CORE_IMAGE=bitcoin/bitcoin:27.1
BITCOIN_PRUNE_MB=5500
BITCOIN_MAX_MEMPOOL_MB=300
BITCOIN_DBCACHE_MB=1024
BITCOIN_HEALTH_START_PERIOD=2h
BITCOIN_P2P_PORT=8333
BITCOIN_RPC_ENABLED=true
BITCOIN_RPC_REQUIRED=true
BITCOIN_RPC_PRUNED_REQUIRED=true
BITCOIN_RPC_USER=kerosene
BITCOIN_RPC_PASSWORD=CHANGE_ME_bitcoin_rpc_password
BITCOIN_RPC_URL=http://bitcoin-pruned-node:8332
BITCOIN_RPC_WALLET=kerosene
BITCOIN_WALLET_PASSPHRASE=
BITCOIN_REINDEX_CHAINSTATE_ONCE=false
BITCOIN_REINDEX_ONCE=false
BITCOIN_ZMQ_ENABLED=true
BITCOIN_ZMQ_RAWTX=tcp://bitcoin-pruned-node:28332
BITCOIN_ZMQ_HASHBLOCK=tcp://bitcoin-pruned-node:28333
BITCOIN_ZMQ_RAWBLOCK=tcp://bitcoin-pruned-node:28334
BITCOIN_INDEXER_BASE_URL=
BITCOIN_ESPLORA_ENABLED=false
BITCOIN_FEE_RECOMMENDATION_URL=
BITCOIN_PLATFORM_MASTER_XPUB=
# Must be the BIP84 account XPUB at m/84'/coin_type'/account', not the root xpub.
BITCOIN_HOT_WALLET_ADDRESS=
BITCOIN_HOT_WALLET_XPUB=
BITCOIN_HOT_WALLET_XPUB_SCAN_RANGE=128
# Local-only: lets onboarding issue deterministic test addresses when no platform XPUB is configured.
TRANSACTIONS_LOCAL_DERIVED_ADDRESS_FALLBACK_ENABLED=false
TRANSACTIONS_BITCOIN_CORE_WALLET_ADDRESS_ENABLED=true
TRANSACTIONS_ONCHAIN_TEST_INSTANT_SETTLEMENT_ENABLED=false
LIGHTNING_LND_IMAGE=lightninglabs/lnd:v0.20.1-beta
LIGHTNING_LND_ENABLED=true
LIGHTNING_LND_HOST=lnd-bitcoind
LIGHTNING_LND_BITCOIN_NODE=bitcoind
LIGHTNING_LND_PORT=10009
LIGHTNING_LND_REST_PORT=8080
LIGHTNING_LND_TLS_SERVER_NAME=lnd-bitcoind
LIGHTNING_LND_TLS_EXTRA_DOMAINS=lnd-bitcoind,lnd-neutrino,localhost
LIGHTNING_LND_TLS_EXTRA_IPS=127.0.0.1
LIGHTNING_LND_TLS_ENABLED=true
LIGHTNING_LND_TLS_CERT_PATH=/lnd/tls.cert
LIGHTNING_LND_MACAROON=
LIGHTNING_LND_MACAROON_PATH=/lnd/data/chain/bitcoin/mainnet/admin.macaroon
LIGHTNING_LND_PROVIDER_NAME=LND_BITCOIND_PRUNED
LIGHTNING_LND_ALIAS=kerosene-lnd-bitcoind
LIGHTNING_LND_COLOR=#D1495B
LIGHTNING_LND_NEUTRINO_CONNECT=
LIGHTNING_LND_NEUTRINO_ADDPEERS=
LIGHTNING_LND_BOOTSTRAP_TIMEOUT_SECONDS=180
LND_WALLET_PASSWORD=

# Comma-separated remote shard onion URLs, for example:
# https://is-shard.onion,https://ch-shard.onion,https://sg-shard.onion
QUORUM_SHARD_URLS=
