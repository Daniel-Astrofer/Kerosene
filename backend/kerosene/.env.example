# ══════════════════════════════════════════════════════════════════
# Kerosene — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=api_system
POSTGRES_PASSWORD=CHANGE_ME_strong_passphrase_here

# ─── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_passphrase

# ─── Spring Boot Secrets ──────────────────────────────────────────
# AES-256 key (32 random bytes, base64-encoded)
# Generate: openssl rand -base64 32
AES_SECRET=CHANGE_ME_aes256_base64_key

# JWT signing secret (HS512 — use 64+ random bytes)
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_jwt_secret

# ─── Alchemy Bitcoin API ──────────────────────────────────────────
API_KEY=CHANGE_ME_alchemy_api_key
