# Testes de Transações Bitcoin (MODO MOCK)
# Importe este arquivo no Postman para testar

{
  "info": {
    "name": "Bitcoin Transactions Mock",
    "description": "Testes sem usar BTC real",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Criar Payment Link",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 0.5,\n  \"description\": \"Pagamento de Teste\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/transactions/create-payment-link",
          "host": ["{{base_url}}"],
          "path": ["transactions", "create-payment-link"]
        }
      }
    },
    {
      "name": "2. Consultar Payment Link",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/transactions/payment-link/{{payment_link_id}}",
          "host": ["{{base_url}}"],
          "path": ["transactions", "payment-link", "{{payment_link_id}}"]
        }
      }
    },
    {
      "name": "3. Confirmar Pagamento (MOCK)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"txid\": \"mock_txid_abc123def456\",\n  \"fromAddress\": \"1TestAddress123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/transactions/payment-link/{{payment_link_id}}/confirm",
          "host": ["{{base_url}}"],
          "path": ["transactions", "payment-link", "{{payment_link_id}}", "confirm"]
        }
      }
    },
    {
      "name": "4. Liberar Valor (Completed)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/transactions/payment-link/{{payment_link_id}}/complete",
          "host": ["{{base_url}}"],
          "path": ["transactions", "payment-link", "{{payment_link_id}}", "complete"]
        }
      }
    },
    {
      "name": "5. Listar Payment Links do Usuário",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/transactions/payment-links",
          "host": ["{{base_url}}"],
          "path": ["transactions", "payment-links"]
        }
      }
    },
    {
      "name": "6. Estimar Taxa de Transação",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/transactions/estimate-fee?amount=0.5",
          "host": ["{{base_url}}"],
          "path": ["transactions", "estimate-fee"],
          "query": [
            {
              "key": "amount",
              "value": "0.5"
            }
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "jwt_token",
      "value": "seu_token_aqui"
    },
    {
      "key": "payment_link_id",
      "value": "pay_teste123"
    }
  ]
}
