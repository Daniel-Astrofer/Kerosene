<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="false">

    <!-- ══════════════════════════════════════════════════════════════════
         KEROSENE — Structured Log Configuration (Financial Platform)
         Domains: runtime | startup | security | auth | kfe | audit | integration | vault | mpc | frontend-api | access
         All logs emit JSON. Routing is driven by the MDC field "logDomain".
         ══════════════════════════════════════════════════════════════════ -->

    <springProperty scope="context" name="serviceName" source="spring.application.name" defaultValue="kerosene"/>
    <springProperty scope="context" name="region"      source="REGION"                  defaultValue="DEV"/>
    <springProperty scope="context" name="shard"       source="SHARD_ID"                defaultValue="local"/>

    <!-- ─── Custom field set shared by all appenders ─────────────────── -->
    <property name="COMMON_FIELDS"
              value="{&quot;service&quot;:&quot;${serviceName}&quot;,&quot;region&quot;:&quot;${region}&quot;,&quot;shard&quot;:&quot;${shard}&quot;}"/>

    <!-- ════════════════════════════════════════════════════════════════
         BASE ENCODER TEMPLATE
         (reused via include — logstash encoder with masking)
         ════════════════════════════════════════════════════════════════ -->

    <!-- ─── SECURITY DOMAIN ──────────────────────────────────────────── -->
    <appender name="SECURITY" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator">
                <marker>SECURITY</marker>
            </evaluator>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>${COMMON_FIELDS}</customFields>
            <includeMdc>true</includeMdc>
            <includeContext>false</includeContext>
            <shortenedLoggerNameLength>64</shortenedLoggerNameLength>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <valueMasker class="source.common.observability.SensitiveDataMasker"/>
            </jsonGeneratorDecorator>
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                <maxDepthPerThrowable>20</maxDepthPerThrowable>
                <maxLength>2048</maxLength>
                <shortenedClassNameLength>40</shortenedClassNameLength>
            </throwableConverter>
        </encoder>
    </appender>

    <!-- ─── KFE DOMAIN ───────────────────────────────────────────────── -->
    <appender name="KFE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator">
                <marker>KFE</marker>
            </evaluator>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>${COMMON_FIELDS}</customFields>
            <includeMdc>true</includeMdc>
            <includeContext>false</includeContext>
            <shortenedLoggerNameLength>64</shortenedLoggerNameLength>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <valueMasker class="source.common.observability.SensitiveDataMasker"/>
            </jsonGeneratorDecorator>
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                <maxDepthPerThrowable>20</maxDepthPerThrowable>
                <maxLength>2048</maxLength>
                <shortenedClassNameLength>40</shortenedClassNameLength>
            </throwableConverter>
        </encoder>
    </appender>

    <!-- Startup/security/auth/integration-specific markers share the same structured encoder shape. -->
    <appender name="STARTUP" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator"><marker>STARTUP</marker></evaluator>
            <onMatch>ACCEPT</onMatch><onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>${COMMON_FIELDS}</customFields><includeMdc>true</includeMdc><includeContext>false</includeContext>
            <shortenedLoggerNameLength>64</shortenedLoggerNameLength>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator"><valueMasker class="source.common.observability.SensitiveDataMasker"/></jsonGeneratorDecorator>
        </encoder>
    </appender>

    <appender name="AUTH" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator"><marker>AUTH</marker></evaluator>
            <onMatch>ACCEPT</onMatch><onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>${COMMON_FIELDS}</customFields><includeMdc>true</includeMdc><includeContext>false</includeContext>
            <shortenedLoggerNameLength>64</shortenedLoggerNameLength>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator"><valueMasker class="source.common.observability.SensitiveDataMasker"/></jsonGeneratorDecorator>
        </encoder>
    </appender>

    <appender name="INTEGRATION" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator"><marker>INTEGRATION</marker></evaluator>
            <onMatch>ACCEPT</onMatch><onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>${COMMON_FIELDS}</customFields><includeMdc>true</includeMdc><includeContext>false</includeContext>
            <shortenedLoggerNameLength>64</shortenedLoggerNameLength>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator"><valueMasker class="source.common.observability.SensitiveDataMasker"/></jsonGeneratorDecorator>
        </encoder>
    </appender>

    <appender name="VAULT" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator"><marker>VAULT</marker></evaluator>
            <onMatch>ACCEPT</onMatch><onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>${COMMON_FIELDS}</customFields><includeMdc>true</includeMdc><includeContext>false</includeContext>
            <shortenedLoggerNameLength>64</shortenedLoggerNameLength>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator"><valueMasker class="source.common.observability.SensitiveDataMasker"/></jsonGeneratorDecorator>
        </encoder>
    </appender>

    <appender name="MPC" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator"><marker>MPC</marker></evaluator>
            <onMatch>ACCEPT</onMatch><onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>${COMMON_FIELDS}</customFields><includeMdc>true</includeMdc><includeContext>false</includeContext>
            <shortenedLoggerNameLength>64</shortenedLoggerNameLength>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator"><valueMasker class="source.common.observability.SensitiveDataMasker"/></jsonGeneratorDecorator>
        </encoder>
    </appender>

    <appender name="FRONTEND_API" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator"><marker>FRONTEND_API</marker></evaluator>
            <onMatch>ACCEPT</onMatch><onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>${COMMON_FIELDS}</customFields><includeMdc>true</includeMdc><includeContext>false</includeContext>
            <shortenedLoggerNameLength>64</shortenedLoggerNameLength>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator"><valueMasker class="source.common.observability.SensitiveDataMasker"/></jsonGeneratorDecorator>
        </encoder>
    </appender>

    <!-- ─── AUDIT DOMAIN (immutable, highest integrity) ─────────────── -->
    <appender name="AUDIT" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator">
                <marker>AUDIT</marker>
            </evaluator>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>${COMMON_FIELDS}</customFields>
            <includeMdc>true</includeMdc>
            <includeContext>false</includeContext>
            <shortenedLoggerNameLength>64</shortenedLoggerNameLength>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <valueMasker class="source.common.observability.SensitiveDataMasker"/>
            </jsonGeneratorDecorator>
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                <maxDepthPerThrowable>30</maxDepthPerThrowable>
                <maxLength>4096</maxLength>
                <shortenedClassNameLength>40</shortenedClassNameLength>
            </throwableConverter>
        </encoder>
    </appender>

    <!-- ─── HTTP ACCESS DOMAIN ───────────────────────────────────────── -->
    <appender name="ACCESS" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.core.filter.EvaluatorFilter">
            <evaluator class="ch.qos.logback.classic.boolex.OnMarkerEvaluator">
                <marker>ACCESS</marker>
            </evaluator>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>${COMMON_FIELDS}</customFields>
            <includeMdc>true</includeMdc>
            <includeContext>false</includeContext>
            <shortenedLoggerNameLength>64</shortenedLoggerNameLength>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <valueMasker class="source.common.observability.SensitiveDataMasker"/>
            </jsonGeneratorDecorator>
        </encoder>
    </appender>

    <!-- ─── GENERAL APPLICATION APPENDER (fallback / Spring internals) ─ -->
    <appender name="APPLICATION" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>${COMMON_FIELDS}</customFields>
            <includeMdc>true</includeMdc>
            <includeContext>false</includeContext>
            <shortenedLoggerNameLength>64</shortenedLoggerNameLength>
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <valueMasker class="source.common.observability.SensitiveDataMasker"/>
            </jsonGeneratorDecorator>
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                <maxDepthPerThrowable>30</maxDepthPerThrowable>
                <maxLength>4096</maxLength>
                <shortenedClassNameLength>40</shortenedClassNameLength>
            </throwableConverter>
        </encoder>
    </appender>

    <!-- ════════════════════════════════════════════════════════════════
         ASYNC WRAPPERS — prevents I/O from blocking request threads
         ════════════════════════════════════════════════════════════════ -->
    <appender name="ASYNC_SECURITY" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="SECURITY"/>
    </appender>

    <appender name="ASYNC_AUTH" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="AUTH"/>
    </appender>

    <appender name="ASYNC_KFE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="KFE"/>
    </appender>

    <appender name="ASYNC_STARTUP" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="STARTUP"/>
    </appender>

    <appender name="ASYNC_INTEGRATION" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="INTEGRATION"/>
    </appender>

    <appender name="ASYNC_VAULT" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="VAULT"/>
    </appender>

    <appender name="ASYNC_MPC" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="MPC"/>
    </appender>

    <appender name="ASYNC_FRONTEND_API" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="FRONTEND_API"/>
    </appender>

    <appender name="ASYNC_AUDIT" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="AUDIT"/>
    </appender>

    <appender name="ASYNC_ACCESS" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="ACCESS"/>
    </appender>

    <!-- ════════════════════════════════════════════════════════════════
         DOMAIN LOGGERS — each package routes to its own named logger
         ════════════════════════════════════════════════════════════════ -->

    <!-- Security: auth, passkeys, honeypot, JWT -->
    <logger name="source.auth"                                    level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_AUTH"/>
    </logger>
    <logger name="source.security"                                level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_SECURITY"/>
    </logger>
    <logger name="kerosene.security"                              level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_SECURITY"/>
    </logger>

    <!-- KFE: financial engine, lightning, on-chain -->
    <logger name="source.kfe"                                     level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_KFE"/>
    </logger>

    <!-- KFE/mining: reserve, liquidity, reconciliation -->
    <logger name="source.mining"                                  level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_KFE"/>
    </logger>

    <logger name="source.vault"                                   level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_VAULT"/>
    </logger>
    <logger name="source.mpc"                                     level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_MPC"/>
    </logger>
    <logger name="source.common.integration"                      level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_INTEGRATION"/>
    </logger>
    <logger name="source.common.startup"                          level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_STARTUP"/>
    </logger>
    <logger name="source.common.frontend"                         level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_FRONTEND_API"/>
    </logger>

    <!-- Audit: sovereign (quorum / raft) -->
    <logger name="source.sovereign"                               level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_AUDIT"/>
    </logger>

    <!-- HTTP Access: request/response logging -->
    <logger name="source.common.infra.logging.LoggingFilter"     level="INFO"  additivity="false">
        <appender-ref ref="ASYNC_ACCESS"/>
    </logger>

    <!-- Silence noisy Spring internals -->
    <logger name="org.springframework.web"          level="WARN"/>
    <logger name="org.springframework.security"     level="WARN"/>
    <logger name="org.springframework.messaging"    level="WARN"/>
    <logger name="org.springframework.web.socket"   level="WARN"/>
    <logger name="org.hibernate.SQL"                level="WARN"/>
    <logger name="com.zaxxer.hikari"                level="WARN"/>

    <!-- ════════════════════════════════════════════════════════════════
         ROOT — catches everything not routed above (Spring, infra, etc.)
         ════════════════════════════════════════════════════════════════ -->
    <root level="${LOGGING_LEVEL_ROOT:-INFO}">
        <appender-ref ref="APPLICATION"/>
    </root>

</configuration>
