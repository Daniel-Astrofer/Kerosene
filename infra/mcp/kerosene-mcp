#!/bin/sh
set -eu

SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(CDPATH= cd -P -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
  LINK_TARGET="$(readlink -- "$SCRIPT_PATH")"
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *) SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET" ;;
  esac
done
SCRIPT_DIR="$(CDPATH= cd -P -- "$(dirname -- "$SCRIPT_PATH")" && pwd)"
PROJECT_ROOT="$(CDPATH= cd -P -- "$SCRIPT_DIR/../.." && pwd)"

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"
export KEROSENE_MCP_ROOT="${KEROSENE_MCP_ROOT:-$PROJECT_ROOT}"
export KEROSENE_MCP_CODEX_FLEET_SCRIPT="${KEROSENE_MCP_CODEX_FLEET_SCRIPT:-$PROJECT_ROOT/AGENTS/codex-fleet-mcp}"
export KEROSENE_MCP_AGY_FLEET_SCRIPT="${KEROSENE_MCP_AGY_FLEET_SCRIPT:-$PROJECT_ROOT/AGENTS/agy-fleet-mcp}"
export KEROSENE_MCP_DEFAULT_SEARCH_TIMEOUT_SECONDS="${KEROSENE_MCP_DEFAULT_SEARCH_TIMEOUT_SECONDS:-900}"
export KEROSENE_MCP_MAX_SEARCH_TIMEOUT_SECONDS="${KEROSENE_MCP_MAX_SEARCH_TIMEOUT_SECONDS:-5400}"
export KEROSENE_MCP_DEFAULT_SEARCH_RESPONSE_CHARS="${KEROSENE_MCP_DEFAULT_SEARCH_RESPONSE_CHARS:-750000}"
export KEROSENE_MCP_MAX_SEARCH_RESPONSE_CHARS="${KEROSENE_MCP_MAX_SEARCH_RESPONSE_CHARS:-2000000}"
export KEROSENE_MCP_MAX_TOOL_RESPONSE_CHARS="${KEROSENE_MCP_MAX_TOOL_RESPONSE_CHARS:-1500000}"

exec python3 "$SCRIPT_DIR/kerosene_server.py" "$@"
